<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusLauncher.ViewModels"
        x:Class="NexusLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="720"
        Background="#1B1D21"
        Title="NexusLauncher">

    <Grid ColumnDefinitions="240,*">
        <Border Grid.Column="0" Background="#14161A" Padding="22">
            <StackPanel Spacing="14">
                <TextBlock Text="NexusLauncher"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="Professional Minecraft Launcher"
                           FontSize="12"
                           Foreground="#7C8794" />

                <Button Content="Home" HorizontalAlignment="Stretch" Click="HomeClick" />
                <Button Content="Jogar" HorizontalAlignment="Stretch" Click="PlayClick" />
                <Button Content="Mods" HorizontalAlignment="Stretch" Click="ModsClick" />
                <Button Content="Versions" HorizontalAlignment="Stretch" Click="VersionsClick" />
                <Button Content="Configurações" HorizontalAlignment="Stretch" Click="SettingsClick" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="28" Background="#1B1D21">
            <ContentControl Content="{Binding Navigation.CurrentView}" />
        </Border>
    </Grid>
</Window>
