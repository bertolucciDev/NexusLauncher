<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusLauncher.ViewModels"
    xmlns:models="using:NexusLauncher.Models"
    xmlns:local="using:NexusLauncher.Helpers"
    x:Class="NexusLauncher.Views.PlayView"
    x:DataType="vm:PlayViewModel">

    <UserControl.Resources>
        <local:BoolInvertConverter x:Key="BoolInvert" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Background="Transparent">
        <!-- Header section -->
        <Grid ColumnDefinitions="*,Auto" Margin="28,24,28,0">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding HeaderTitle}" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.ForegroundMain}" />
                <TextBlock Text="{Binding HeaderSubtitle}" FontSize="13"
                           Foreground="{DynamicResource Brush.ForegroundMuted}" />
            </StackPanel>
            <Border Grid.Column="1" Background="{DynamicResource Brush.Surface}" Padding="14,10"
                    VerticalAlignment="Top">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
                    <Border Width="32" Height="32" Background="{DynamicResource Brush.SurfaceAlt}">
                        <TextBlock Text="●" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.ForegroundMuted}" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="{Binding Nickname}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.ForegroundMain}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="120" />
                        <TextBlock Text="Online" FontSize="10"
                                   Foreground="{DynamicResource Brush.Accent}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Margin="28,0">
            <Border Background="{DynamicResource Brush.Surface}" Padding="28">
                <StackPanel Spacing="24">
                    <!-- Title -->
                    <TextBlock Text="{Binding ButtonText}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.ForegroundMain}"
                               HorizontalAlignment="Center" />

                    <!-- Version Selector -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding VersionLabel}" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.ForegroundDim}" />
                        <ComboBox x:Name="VersionCombo"
                                  ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                  Background="{DynamicResource Brush.SurfaceAlt}"
                                  MaxDropDownHeight="280"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.Styles>
                                <Style Selector="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ComboBox.Styles>
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:MinecraftVersionInfo">
                                    <Grid>
                                        <Border Padding="10,10,10,4" IsVisible="{Binding IsGroupHeader}" Background="Transparent">
                                            <TextBlock Text="{Binding Id}" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource Brush.ForegroundMuted}" />
                                        </Border>
                                        <Border Padding="10,7" IsVisible="{Binding IsGroupHeader, Converter={StaticResource BoolInvert}}"
                                                Background="Transparent">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding BadgeIcon}" MinWidth="22" />
                                                <TextBlock Text="{Binding Id}" Foreground="{DynamicResource Brush.ForegroundMain}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="·" Foreground="{DynamicResource Brush.ForegroundDim}" />
                                                <TextBlock Text="{Binding FriendlyType}" Foreground="{DynamicResource Brush.Accent}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Play Button -->
                    <Button Content="{Binding ButtonText}"
                            Command="{Binding PrimaryActionCommand}"
                            Classes="Accent"
                            HorizontalAlignment="Stretch" Height="48" FontSize="16" />

                    <!-- Status text -->
                    <TextBlock Text="{Binding LastUpdateText}" Foreground="{DynamicResource Brush.ForegroundDim}"
                               FontSize="11" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Progress bar -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="28,8,28,20" Spacing="6"
                    IsVisible="{Binding IsBusy}">
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="4"
                         HorizontalAlignment="Stretch" />
            <TextBlock Text="{Binding ProgressDetail}" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       FontSize="12" />
        </StackPanel>
    </Grid>
</UserControl>
