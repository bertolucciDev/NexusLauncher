<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusLauncher.ViewModels"
        x:Class="NexusLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="760"
        MinWidth="1060"
        MinHeight="680"
        Background="#0F1218"
        Title="Nexus Launcher">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A9B4C3" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#1B2330" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0" Background="#111620" Padding="20" BorderBrush="#202938" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                        <Border Width="44" Height="44" CornerRadius="14" Background="#7C5CFF">
                            <TextBlock Text="N" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Nexus Launcher" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Minecraft, do seu jeito" FontSize="12" Foreground="#6F7C8F" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8" Margin="0,34,0,0">
                    <TextBlock Text="NAVEGAÇÃO" Foreground="#596579" FontSize="11" FontWeight="SemiBold" Margin="14,0,0,6" />
                    <Button Classes="nav" Content="⌂   Home" Click="HomeClick" />
                    <Button Classes="nav" Content="▶   Jogar" Click="PlayClick" />
                    <Button Classes="nav" Content="▦   Versões" Click="VersionsClick" />
                    <Button Classes="nav" Content="↓   Downloads" Click="ModsClick" />
                    <Button Classes="nav" Content="⚙   Configurações" Click="SettingsClick" />
                </StackPanel>

                <Border Grid.Row="2" Background="#171D28" CornerRadius="16" Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Status" Foreground="#7CE1C4" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Pronto para jogar" Foreground="White" FontSize="14" />
                        <TextBlock Text="Downloads aparecem aqui sem abrir janelas extras." Foreground="#7F8CA0" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="30" Background="#0F1218">
            <ContentControl Content="{Binding Navigation.CurrentView}" />
        </Border>
    </Grid>
</Window>
