<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusLauncher.ViewModels"
    x:Class="NexusLauncher.Views.HomeView"
    x:DataType="vm:HomeViewModel">

    <Border Background="#161616" CornerRadius="16" Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Bem-vindo ao NexusLauncher"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <TextBlock Text="Status do launcher"
                       Foreground="#9bb0c8"
                       FontSize="16" />

            <StackPanel Spacing="8">
                <TextBlock Text="{Binding JavaStatus}"
                           Foreground="White" />
                <TextBlock Text="{Binding LaunchStatus}"
                           Foreground="White" />
                <TextBlock Text="{Binding SelectedVersion}"
                           Foreground="#7ce1c4" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>