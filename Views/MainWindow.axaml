<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusLauncher.ViewModels"
        x:Class="NexusLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="720"
        Title="NexusLauncher">

    <Grid ColumnDefinitions="220,*">
        <Border Grid.Column="0" Background="#121212" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock Text="NexusLauncher"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White" />

                <Button Content="Home"
                        HorizontalAlignment="Stretch"
                        Click="HomeClick" />
                <Button Content="Play"
                        HorizontalAlignment="Stretch"
                        Click="PlayClick" />
                <Button Content="Settings"
                        HorizontalAlignment="Stretch"
                        Click="SettingsClick" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="24" Background="#1a1a1a">
            <ContentControl Content="{Binding Navigation.CurrentView}" />
        </Border>
    </Grid>
</Window>