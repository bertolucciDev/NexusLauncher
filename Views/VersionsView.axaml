<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusLauncher.ViewModels"
    xmlns:models="using:NexusLauncher.Models"
    x:Class="NexusLauncher.Views.VersionsView"
    x:DataType="vm:VersionsViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="VersionCardTemplate" x:DataType="models:MinecraftVersionInfo">
            <Border Background="#171D28" CornerRadius="18" Padding="16" Margin="0,0,0,10" BorderBrush="#263145" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border Width="42" Height="42" Background="#101620" CornerRadius="12">
                        <TextBlock Text="{Binding BadgeIcon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{Binding Id}" Foreground="White" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding BaseVersionText}" Foreground="#9BB0C8" />
                        <TextBlock Text="{Binding FriendlyType}" Foreground="#7CE1C4" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="{Binding FavoriteIcon}" Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteCommand}" CommandParameter="{Binding}" VerticalAlignment="Top" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <StackPanel Spacing="6">
            <TextBlock Text="Versões" Foreground="White" FontSize="36" FontWeight="SemiBold" />
            <TextBlock Text="Gerencie releases, snapshots, loaders e modpacks com nomes personalizados." Foreground="#8B98AA" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,300" ColumnSpacing="16">
            <TextBox Text="{Binding SearchText, Mode=TwoWay}" Watermark="Pesquisar por versão, loader ou modpack..." Padding="14" />
            <Border Grid.Column="1" Background="#171D28" CornerRadius="16" Padding="14" IsVisible="{Binding HasLastPlayedVersion}">
                <StackPanel Spacing="4">
                    <TextBlock Text="ÚLTIMA VERSÃO JOGADA" Foreground="#7CE1C4" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastPlayedVersionName}" Foreground="White" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="2">
            <TabItem Header="Releases"><ScrollViewer><ItemsControl ItemsSource="{Binding Releases}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
            <TabItem Header="Snapshots"><ScrollViewer><TextBlock Text="Snapshots oficiais aparecerão aqui." Foreground="#8B98AA" Margin="12" /></ScrollViewer></TabItem>
            <TabItem Header="Forge"><ScrollViewer><ItemsControl ItemsSource="{Binding Modded}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
            <TabItem Header="Fabric"><ScrollViewer><ItemsControl ItemsSource="{Binding Modded}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
            <TabItem Header="NeoForge"><ScrollViewer><ItemsControl ItemsSource="{Binding Modded}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
            <TabItem Header="Quilt"><ScrollViewer><ItemsControl ItemsSource="{Binding Modded}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
            <TabItem Header="Modificados"><ScrollViewer><ItemsControl ItemsSource="{Binding Installed}" ItemTemplate="{StaticResource VersionCardTemplate}" /></ScrollViewer></TabItem>
        </TabControl>
    </Grid>
</UserControl>
