<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:vm="using:NexusLauncher.ViewModels"
               xmlns:conv="using:NexusLauncher.Helpers" x:Class="NexusLauncher.Views.SettingsView"
               x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalAlignment="Stretch" Background="Transparent">
        <StackPanel Spacing="24" Margin="28,24,28,28">
            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding TitleLabel}" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.ForegroundMain}" />
                <TextBlock Text="{Binding SubtitleLabel}" FontSize="13"
                           Foreground="{DynamicResource Brush.ForegroundMuted}" />
            </StackPanel>

            <!-- Settings cards -->
            <WrapPanel>
                <!-- Performance -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionPerformance}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="RAM" Foreground="{DynamicResource Brush.ForegroundMain}" FontSize="13" />
                                <TextBlock Grid.Column="1" Text="{Binding AllocatedRamText}"
                                           Foreground="{DynamicResource Brush.Accent}" FontSize="12"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Slider Minimum="2" Maximum="{Binding MaxRamGb}"
                                    Value="{Binding AllocatedRamGb, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="JVM Arguments" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <TextBox Text="{Binding JvmArgs, Mode=TwoWay}"
                                     PlaceholderText="-XX:+UseG1GC -XX:+ParallelRefProcEnabled" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Java -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionJava}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Java" Foreground="{DynamicResource Brush.ForegroundMain}" FontSize="13" />
                            <TextBlock Text="{Binding JavaPath}" FontSize="12"
                                       Foreground="{DynamicResource Brush.ForegroundMuted}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="{Binding DetectButtonLabel}" Classes="Secondary" Padding="14,7" FontSize="12"
                                    Command="{Binding DetectJavaCommand}" />
                            <Button Content="Selecionar" Classes="Secondary" Padding="14,7" FontSize="12"
                                    Command="{Binding SelectJavaCommand}" />
                            <CheckBox Content="Auto download" IsChecked="{Binding DownloadJavaAutomatically}"
                                      Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Directories -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionDirectories}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Minecraft directory" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <TextBox Text="{Binding MinecraftDirectory, Mode=TwoWay}"
                                     PlaceholderText="C:\Users\...\AppData\Roaming\.minecraft" />
                        </StackPanel>
                        <Button Content="{Binding OpenFolderButtonLabel}" Classes="Secondary" Padding="14,7" FontSize="12"
                                HorizontalAlignment="Left" Command="{Binding OpenMinecraftFolderCommand}" />
                    </StackPanel>
                </Border>

                <!-- Window -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionWindow}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Resolution" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding SelectedResolution}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <CheckBox Content="Fullscreen" IsChecked="{Binding Fullscreen}" />
                    </StackPanel>
                </Border>

                <!-- Behavior -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionBehavior}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="10">
                            <CheckBox Content="Close on launch" IsChecked="{Binding CloseLauncherOnGameStart}" />
                            <CheckBox Content="Reopen after closing" IsChecked="{Binding ReopenLauncherAfterGameClose}" />
                            <CheckBox Content="Minimize on launch" IsChecked="{Binding MinimizeLauncherOnGameStart}" />
                            <CheckBox Content="Keep in background" IsChecked="{Binding KeepLauncherInBackground}" />
                            <CheckBox Content="Auto update launcher" IsChecked="{Binding AutoUpdateLauncher}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Appearance -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionAppearance}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Language" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Theme" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- CurseForge -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="CurseForge" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="API Key" Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                            <TextBox Text="{Binding CurseForgeApiKey, Mode=TwoWay}"
                                     PlaceholderText="Chave do console.curseforge.com" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version filters -->
                <Border Background="{DynamicResource Brush.Surface}" Padding="20" MinWidth="320" MaxWidth="480" Margin="0,0,16,16">
                    <StackPanel Spacing="16">
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,0,0,12">
                            <TextBlock Text="{Binding SectionVersions}" Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="Bold" FontSize="12" />
                        </Border>
                        <TextBlock Text="{Binding SubsectionCategoryFilters}"
                                   Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="12" />
                        <ItemsControl ItemsSource="{Binding CategoryFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryFilterItem">
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}"
                                              Margin="0,2,16,2" FontSize="13" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Save bar -->
            <Border Background="{DynamicResource Brush.Surface}" Padding="16">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource Brush.Success}"
                               IsVisible="{Binding SaveStatusIsSuccess}" />
                    <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource Brush.Error}"
                               IsVisible="{Binding SaveStatusIsSuccess, Converter={x:Static conv:BoolConverters.Not}}" />
                    <Button Grid.Column="1" Content="{Binding RestoreButtonLabel}" Classes="Secondary" Padding="16,8" FontSize="12"
                            Command="{Binding RestoreDefaultsCommand}" />
                    <Button Grid.Column="2" Content="{Binding SaveButtonLabel}" Classes="Primary" Padding="24,8" FontSize="13"
                            Command="{Binding SaveCommand}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
